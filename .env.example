# Required
OPENAI_API_KEY=sk-your-openai-api-key

# Optional — defaults shown
# DATA_DIR=./data
# DATABASE_PATH=./data/shopping.db
# RULES_PATH=./data/rules.yaml
# COOKIES_PATH=./data/cookies.json
# CONFIG_DIR=./config
# BROWSER_HEADLESS=true
# LOG_LEVEL=INFO

# API authentication (required unless ALLOW_UNAUTHENTICATED=true)
# API_SECRET_KEY=your-secret-key-here

# Set to "true" to allow unauthenticated access (development only)
# ALLOW_UNAUTHENTICATED=false

# CORS origins (comma-separated, default: http://localhost:3000)
# CORS_ORIGINS=http://localhost:3000
