#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

echo "=== Pre-commit: Backend checks ==="
cd "$ROOT/backend"

echo "[1/7] ruff check..."
uv run ruff check .

echo "[2/7] ruff format --check..."
uv run ruff format --check .

echo "[3/7] mypy..."
uv run mypy app/

echo "[4/7] pytest (unit tests)..."
uv run pytest -m "not integration" -q

echo "=== Pre-commit: Frontend checks ==="
cd "$ROOT/frontend"

echo "[5/7] eslint..."
npm run lint --silent

echo "[6/7] typecheck..."
npm run typecheck --silent

echo "[7/7] vitest..."
npm run test --silent

echo "=== All pre-commit checks passed ==="
